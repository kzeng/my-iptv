{
  "name": "my-iptv",
  "version": "1.0.0",
  "description": "IPTV Player",
  "main": "main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "start": "electron . 2>/dev/null",
    "dev": "electron . --dev",
    "rebuild:native": "node scripts/patch-v8-headers.js && CXXFLAGS=\"-std=c++20\" electron-rebuild -f -w better-sqlite3",
    "build:m3u": "node scripts/parse-m3u.js",
    "build": "npm run rebuild:native && npm run build:m3u && node scripts/package.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "hls.js": "^1.5.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "electron": "^33.0.0",
    "electron-packager": "^17.1.2"
  }
}
